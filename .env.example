# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct DB connection string for supabase CLI (--db-url)
# Format: postgresql://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# Gemini / Google Generative AI
GOOGLE_GENERATIVE_AI_API_KEY=

# Upstash Ratelimit (optional in dev — leave blank to disable)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin bootstrap (comma-separated emails)
ADMIN_EMAILS=

# App
APP_URL=http://localhost:3000
